# =================================
# Application Settings
# =================================

# Secret key used for Flask session signing.
# IMPORTANT: You MUST change this in production.
# If not set, a random key will be generated at runtime (not recommended for production).
MATRIX_SESSION_SIGNING_KEY="changeme"


# =================================
# Optional Server Configuration
# =================================

# Public server name (e.g., example.com).
# Used when generating absolute URLs (sitemap.xml, robots.txt).
# Leave unset or empty if not needed.
# MATRIX_SERVER_NAME="localhost"

# URL scheme used for external links (http or https).
# Set to "https" if running behind a reverse proxy that handles HTTPS (e.g., nginx, Cloudflare).
# MATRIX_URL_SCHEME="http"


# =================================
# Runtime Settings
# =================================

# Enable Flask debug mode.
# IMPORTANT: NEVER enable this in production.
MATRIX_DEBUG="false"

# Host address to bind the server to.
# MATRIX_HOST="0.0.0.0"

# Port to run the server on.
# MATRIX_PORT="5000"


# =================================
# Rate Limiting
# =================================

# Enable request rate limiting (recommended for production).
# Set to "false" to disable all limits.
# MATRIX_RATE_LIMIT_ENABLED="true"
